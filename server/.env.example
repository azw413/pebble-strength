# Copy to server/.env and fill in.

# SQLite database file (created on first run)
DATABASE_URL=strength.db

# Public base URL of this server (used for OAuth redirect URIs)
BASE_URL=http://localhost:8080

# Google OAuth client (https://console.cloud.google.com/apis/credentials)
# Create an "OAuth client ID" of type "Web application" with redirect URI:
#   <BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to 1 to enable the local-only "Dev login" button (no Google needed).
# Never enable in production.
DEV_LOGIN=1

# Address to bind. 127.0.0.1 for local; 0.0.0.0 behind a proxy/tunnel.
BIND_ADDR=127.0.0.1
PORT=8080

# ---------------------------------------------------------------------------
# Production example (pebblestrength.app), served over HTTPS by a
# reverse proxy or Cloudflare Tunnel in front of this process:
#
#   DATABASE_URL=/var/lib/strength/strength.db
#   BASE_URL=https://pebblestrength.app
#   GOOGLE_CLIENT_ID=<your-web-client-id>.apps.googleusercontent.com
#   GOOGLE_CLIENT_SECRET=<your-secret>
#   DEV_LOGIN=0
#   BIND_ADDR=127.0.0.1
#   PORT=8090
#
# The .app TLD is HSTS-preloaded: it will ONLY load over HTTPS, so TLS
# termination in front of the app is mandatory. Register the redirect URI
# https://pebblestrength.app/auth/google/callback in the Google console.

# Email allowed to view the private /stats dashboard (unset = any logged-in user).
ADMIN_EMAIL=
# Directory for self-logged page-view analytics (default: analytics/).
ANALYTICS_DIR=analytics
